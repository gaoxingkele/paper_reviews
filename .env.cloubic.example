# ===== Cloubic unified routing for OpenAI-compatible LLM calls =====
# Optional: only affects chat/completions style model calls.
# Provider-specific search APIs remain direct.

CLOUBIC_ENABLED=true
CLOUBIC_API_KEY=
CLOUBIC_BASE_URL=https://api.cloubic.com/v1/chat/completions

# Only listed providers route through Cloubic.
CLOUBIC_ROUTED_PROVIDERS=gemini,grok

# Non-reasoning / general model chains
CLOUBIC_GEMINI_MODEL=gemini-3.1-pro-preview,gemini-3-flash-preview
CLOUBIC_GROK_MODEL=grok-4-1-fast-non-reasoning

# Reasoning model chains
CLOUBIC_GEMINI_REASONING_MODEL=gemini-3.1-pro-preview
CLOUBIC_GROK_REASONING_MODEL=grok-4-1-fast-reasoning
